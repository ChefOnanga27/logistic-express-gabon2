# ============================================
# Configuration Nodemailer — Logistic Express Gabon
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================

# Serveur SMTP (Gmail exemple)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Identifiants SMTP
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application

# Email destinataire des demandes de devis et contacts
CONTACT_EMAIL=contact@logistic-express-gabon.ga

# Email expéditeur affiché
FROM_NAME=Logistic Express Gabon
FROM_EMAIL=noreply@logistic-express-gabon.ga

# Port du serveur
PORT=3000

# Sécurité session admin
SESSION_SECRET=changez-cette-valeur-en-production-leg2026
