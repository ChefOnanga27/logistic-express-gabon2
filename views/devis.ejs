<%- include('partials/header') %>

<section class="page-hero">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <h1>Demande de Devis</h1>
    <nav class="breadcrumb"><a href="/">Accueil</a> <i class="fa fa-chevron-right"></i> Devis</nav>
  </div>
</section>

<section class="section" style="background:var(--bg);">
  <div class="container devis-layout">

    <!-- Formulaire -->
    <div class="devis-form-box">
      <h3><i class="fa fa-file-invoice" style="color:var(--primary-blue);"></i> Votre demande de devis</h3>
      <p class="devis-intro">Remplissez ce formulaire et recevez votre devis personnalisé sous <strong>2 à 4 heures</strong> par email.</p>

      <% if (success) { %>
      <div class="alert-success">
        <i class="fa fa-check-circle"></i>
        <div>
          <strong>Demande envoyée avec succès !</strong>
          <p>Vous recevrez votre devis par email sous 2–4 heures. Nous vous avons également envoyé un accusé de réception.</p>
        </div>
      </div>
      <% } %>

      <% if (error) { %>
      <div class="alert-error">
        <i class="fa fa-triangle-exclamation"></i>
        <div>
          <strong>Erreur lors de l'envoi</strong>
          <p>Veuillez réessayer ou nous contacter directement au +241 074 00 00 00.</p>
        </div>
      </div>
      <% } %>

      <% if (!success) { %>
      <form action="/devis" method="POST" class="devis-form">

        <div class="form-section-title"><i class="fa fa-user"></i> Vos coordonnées</div>
        <div class="form-row">
          <div class="form-group">
            <label>Nom complet *</label>
            <input type="text" name="nom" placeholder="Jean Dupont" required />
          </div>
          <div class="form-group">
            <label>Email *</label>
            <input type="email" name="email" placeholder="vous@email.com" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Téléphone *</label>
            <input type="tel" name="telephone" placeholder="+241 0X XXX XXXX" required />
          </div>
          <div class="form-group">
            <label>Entreprise</label>
            <input type="text" name="entreprise" placeholder="Nom de votre société (optionnel)" />
          </div>
        </div>

        <div class="form-section-title"><i class="fa fa-box"></i> Détails de l'envoi</div>
        <div class="form-row">
          <div class="form-group">
            <label>Type de service *</label>
            <select name="typeService" required>
              <option value="">Sélectionner un service...</option>
              <% services.forEach(s => { %>
              <option value="<%= s.titre %>"><%= s.titre %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Poids / Volume estimé</label>
            <input type="text" name="poids" placeholder="Ex: 500 kg, 2 palettes, 1 conteneur 20'" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Ville d'origine *</label>
            <input type="text" name="origine" placeholder="Ex: Libreville" required />
          </div>
          <div class="form-group">
            <label>Destination *</label>
            <input type="text" name="destination" placeholder="Ex: Port-Gentil, Paris, Douala..." required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Date d'expédition souhaitée</label>
            <input type="date" name="dateExpedition" />
          </div>
          <div class="form-group">
            <label>Type de marchandise</label>
            <input type="text" name="typeMarchandise" placeholder="Ex: produits alimentaires, matériaux..." />
          </div>
        </div>
        <div class="form-group">
          <label>Description / Informations complémentaires</label>
          <textarea name="description" rows="4" placeholder="Précisez toute information utile : conditionnement, contraintes particulières, délais impératifs..."></textarea>
        </div>

        <div class="form-group form-checkbox">
          <label class="checkbox-label">
            <input type="checkbox" name="urgent" value="oui" />
            <span class="checkmark"></span>
            Envoi urgent (supplément possible)
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="assurance" value="oui" />
            <span class="checkmark"></span>
            Je souhaite une assurance cargo tous risques
          </label>
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <i class="fa fa-paper-plane"></i> Envoyer ma demande de devis
        </button>
        <p class="form-legal"><i class="fa fa-lock"></i> Vos données sont confidentielles et ne seront pas partagées avec des tiers.</p>
      </form>
      <% } %>
    </div>

    <!-- Sidebar infos -->
    <aside class="devis-sidebar">
      <div class="sidebar-card cta-card" style="border-top:4px solid var(--primary-yellow);">
        <div class="cta-card-icon" style="background:rgba(245,197,24,0.15);color:var(--primary-yellow);"><i class="fa fa-bolt"></i></div>
        <h4>Devis sous 2–4h</h4>
        <p>Nos commerciaux analysent votre demande et vous envoient une proposition tarifaire personnalisée rapidement.</p>
      </div>

      <div class="sidebar-card">
        <h4><i class="fa fa-phone"></i> Besoin d'un devis immédiat ?</h4>
        <p style="color:var(--text-muted);font-size:0.9rem;margin-bottom:14px;">Appelez-nous directement, nous établissons votre devis en temps réel.</p>
        <a href="tel:+24174000000" class="btn btn-primary btn-block"><i class="fa fa-phone"></i> +241 074 00 00 00</a>
        <a href="https://wa.me/24174000000" class="btn-whatsapp" target="_blank"><i class="fab fa-whatsapp"></i> WhatsApp</a>
      </div>

      <div class="sidebar-card">
        <h4><i class="fa fa-grid-2"></i> Nos services</h4>
        <ul class="sidebar-services">
          <% services.forEach(s => { %>
          <li>
            <a href="/services/<%= s.slug %>">
              <span class="ss-icon" style="background:<%= s.color %>18;color:<%= s.color %>;"><i class="fa <%= s.icon %>"></i></span>
              <span class="ss-label"><%= s.titre %></span>
              <i class="fa fa-chevron-right ss-arrow"></i>
            </a>
          </li>
          <% }) %>
        </ul>
      </div>

      <div class="sidebar-card garanties-card">
        <h4><i class="fa fa-shield-halved"></i> Nos garanties</h4>
        <ul class="garanties-list">
          <li><i class="fa fa-check"></i> Devis 100% gratuit et sans engagement</li>
          <li><i class="fa fa-check"></i> Réponse sous 2–4 heures ouvrables</li>
          <li><i class="fa fa-check"></i> Tarifs transparents, sans frais cachés</li>
          <li><i class="fa fa-check"></i> Assurance cargo disponible</li>
          <li><i class="fa fa-check"></i> Suivi en temps réel inclus</li>
        </ul>
      </div>
    </aside>

  </div>
</section>

<%- include('partials/footer') %>
