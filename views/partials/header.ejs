<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Logistic Express Gabon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div class="container topbar-inner">
    <div class="topbar-left">
      <span><i class="fa fa-phone"></i> +241 074 00 00 00</span>
      <span><i class="fa fa-envelope"></i> contact@logistic-express-gabon.ga</span>
    </div>
    <div class="topbar-right">
      <span><i class="fa fa-clock"></i> Lun–Sam : 07h30 – 18h00</span>
      <a href="/suivi" class="topbar-track"><i class="fa fa-search"></i> Suivre mon colis</a>
    </div>
  </div>
</div>

<!-- Navbar -->
<nav class="navbar" id="navbar">
  <div class="container navbar-inner">
    <a href="/" class="logo">
      <img src="/images/logo.jpeg" alt="Logistic Express Gabon" class="logo-img" />
    </a>

    <button class="burger" id="burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links" id="nav-links">
      <li><a href="/" class="<%= page === 'home' ? 'active' : '' %>">Accueil</a></li>
      <li><a href="/services" class="<%= page === 'services' ? 'active' : '' %>">Services</a></li>
      <li><a href="/blog" class="<%= page === 'blog' ? 'active' : '' %>">Blog</a></li>
      <li><a href="/a-propos" class="<%= page === 'about' ? 'active' : '' %>">À Propos</a></li>
      <li><a href="/contact" class="<%= page === 'contact' ? 'active' : '' %>">Contact</a></li>
      <li><a href="/devis" class="btn-nav-devis <%= page === 'devis' ? 'active' : '' %>"><i class="fa fa-file-invoice"></i> Devis gratuit</a></li>
      <li><a href="/suivi" class="btn-nav <%= page === 'suivi' ? 'active' : '' %>"><i class="fa fa-box"></i> Suivi</a></li>
    </ul>
  </div>
</nav>
