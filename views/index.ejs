<%- include('partials/header') %>

<!-- ============================
     HERO SLIDER (3 slides)
     ============================ -->
<section class="hero-slider" id="heroSlider">

  <!-- Slide 1 — Présentation entreprise -->
  <div class="slide slide-1 active">
    <div class="slide-overlay"></div>
    <div class="slide-bg-pattern"></div>
    <div class="container slide-content">
      <div class="slide-inner">
        <span class="slide-badge"><i class="fa fa-star"></i> N°1 de la Logistique au Gabon</span>
        <h1>Votre partenaire<br>logistique <span class="highlight-y">de confiance</span></h1>
        <p>Depuis 2014, Logistic Express Gabon connecte les entreprises et les particuliers à travers les 9 provinces du Gabon. Fiabilité, rapidité et expertise à chaque livraison.</p>
        <div class="slide-btns">
          <a href="/devis" class="btn btn-yellow"><i class="fa fa-file-invoice"></i> Demander un devis</a>
          <a href="/a-propos" class="btn btn-outline-w">Découvrir LEG <i class="fa fa-arrow-right"></i></a>
        </div>
        <div class="slide-stats">
          <div class="sstat"><strong>10+</strong><span>Ans d'expérience</span></div>
          <div class="sstat-sep"></div>
          <div class="sstat"><strong>5 000+</strong><span>Livraisons/an</span></div>
          <div class="sstat-sep"></div>
          <div class="sstat"><strong>9</strong><span>Provinces</span></div>
          <div class="sstat-sep"></div>
          <div class="sstat"><strong>98%</strong><span>Satisfaction</span></div>
        </div>
      </div>
      <div class="slide-visual s1-visual">
        <div class="sv-icon-main"><i class="fa fa-globe-africa"></i></div>
        <div class="sv-orbit sv-orbit-1"><div class="sv-dot"><i class="fa fa-truck"></i></div></div>
        <div class="sv-orbit sv-orbit-2"><div class="sv-dot"><i class="fa fa-ship"></i></div></div>
        <div class="sv-orbit sv-orbit-3"><div class="sv-dot"><i class="fa fa-plane"></i></div></div>
      </div>
    </div>
  </div>

  <!-- Slide 2 — Services routier & maritime -->
  <div class="slide slide-2">
    <div class="slide-overlay"></div>
    <div class="slide-bg-pattern"></div>
    <div class="container slide-content">
      <div class="slide-inner">
        <span class="slide-badge"><i class="fa fa-truck"></i> Transport Terrestre & Maritime</span>
        <h1>Route &amp; Mer,<br>partout au <span class="highlight-y">Gabon</span></h1>
        <p>Livraisons porte-à-porte dans toutes les provinces, liaisons maritimes hebdomadaires entre Libreville et Port-Gentil. Votre fret entre de bonnes mains.</p>
        <div class="slide-service-cards">
          <div class="ssc">
            <i class="fa fa-truck"></i>
            <div>
              <strong>Transport Routier</strong>
              <span>J+1 Libreville · J+4 province</span>
            </div>
          </div>
          <div class="ssc">
            <i class="fa fa-ship"></i>
            <div>
              <strong>Transport Maritime</strong>
              <span>Départ hebdomadaire · FCL & LCL</span>
            </div>
          </div>
          <div class="ssc">
            <i class="fa fa-warehouse"></i>
            <div>
              <strong>Entreposage</strong>
              <span>5 000 m² · Owendo & Oloumi</span>
            </div>
          </div>
        </div>
        <div class="slide-btns">
          <a href="/services/transport-routier" class="btn btn-yellow"><i class="fa fa-truck"></i> Transport Routier</a>
          <a href="/services/transport-maritime" class="btn btn-outline-w"><i class="fa fa-ship"></i> Transport Maritime</a>
        </div>
      </div>
      <div class="slide-visual s2-visual">
        <div class="s2-truck-anim"><i class="fa fa-truck-moving"></i></div>
        <div class="s2-road"></div>
        <div class="s2-ship-anim"><i class="fa fa-ship"></i></div>
        <div class="s2-wave"></div>
      </div>
    </div>
  </div>

  <!-- Slide 3 — Services aérien & import/export -->
  <div class="slide slide-3">
    <div class="slide-overlay"></div>
    <div class="slide-bg-pattern"></div>
    <div class="container slide-content">
      <div class="slide-inner">
        <span class="slide-badge"><i class="fa fa-plane"></i> Fret Aérien & Commerce International</span>
        <h1>Le monde à<br>votre <span class="highlight-y">portée</span></h1>
        <p>Fret aérien express vers 150+ destinations en 24–72h. Gestion complète de vos opérations d'import-export avec notre équipe de commissionnaires agréés.</p>
        <div class="slide-service-cards">
          <div class="ssc">
            <i class="fa fa-plane"></i>
            <div>
              <strong>Transport Aérien</strong>
              <span>Express 24–72h · 150+ destinations</span>
            </div>
          </div>
          <div class="ssc">
            <i class="fa fa-globe-africa"></i>
            <div>
              <strong>Import / Export</strong>
              <span>Commissionnaires agréés · DGD Gabon</span>
            </div>
          </div>
          <div class="ssc">
            <i class="fa fa-box"></i>
            <div>
              <strong>Déménagement</strong>
              <span>Particuliers & entreprises</span>
            </div>
          </div>
        </div>
        <div class="slide-btns">
          <a href="/services/transport-aerien" class="btn btn-yellow"><i class="fa fa-plane"></i> Fret Aérien</a>
          <a href="/services/import-export" class="btn btn-outline-w"><i class="fa fa-globe-africa"></i> Import/Export</a>
        </div>
      </div>
      <div class="slide-visual s3-visual">
        <div class="s3-plane-anim"><i class="fa fa-plane"></i></div>
        <div class="s3-clouds">
          <div class="s3-cloud"></div>
          <div class="s3-cloud c2"></div>
          <div class="s3-cloud c3"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Controls -->
  <button class="slider-arrow slider-prev" id="sliderPrev" aria-label="Précédent">
    <i class="fa fa-chevron-left"></i>
  </button>
  <button class="slider-arrow slider-next" id="sliderNext" aria-label="Suivant">
    <i class="fa fa-chevron-right"></i>
  </button>

  <!-- Dots -->
  <div class="slider-dots">
    <button class="sdot active" data-idx="0"></button>
    <button class="sdot" data-idx="1"></button>
    <button class="sdot" data-idx="2"></button>
  </div>

  <!-- Progress bar -->
  <div class="slider-progress"><div class="slider-progress-bar" id="sliderProgress"></div></div>
</section>

<!-- Tracking bar -->
<section class="track-bar">
  <div class="container">
    <form action="/suivi" method="POST" class="track-form">
      <i class="fa fa-box-open"></i>
      <input type="text" name="numero" placeholder="Entrez votre numéro de suivi ex: LEG-2026-08471..." required />
      <button type="submit" class="btn btn-primary">Suivre <i class="fa fa-arrow-right"></i></button>
    </form>
  </div>
</section>

<<!-- Services -->
<section class="section services-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Ce que nous faisons</span>
      <h2>Nos Services Logistiques</h2>
      <p>Une gamme complète de solutions de transport adaptées aux besoins des entreprises et des particuliers.</p>
    </div>

    <% const serviceImages = {
      'achat-international':      '/images/achat.jpg',
      'reception-colis':          '/images/reception.jpg',
      'consolidation':            '/images/consolidation.jpg',
      'transport-international':  '/images/transport.jpg',
      'dedouanement':             '/images/douane.jpg',
      'assistance-douane':        '/images/assistance.jpg',
      'livraison-locale':         '/images/livraison.jpg',
      'suivi-colis':              '/images/suivi.jpg',
      'paiement-reception':       '/images/paiement.jpg'
    }; %>

    <div class="services-grid">
      <% services.forEach((s, i) => { %>
        <% const serviceImage    = serviceImages[s.slug] || '/images/hero-logistics.jpg'; %>
        <% const serviceIconStyle = i !== 1 ? 'background:' + s.color + '18; color:' + s.color + ';' : ''; %>

        <div class="service-card <%= i === 1 ? 'featured' : '' %>">
          <div class="service-card-image" style="background-image: url('<%= serviceImage %>')"></div>
          <div class="service-icon" style="<%= serviceIconStyle %>">
            <i class="fa <%= s.icon %>"></i>
          </div>
          <h3><%= s.titre %></h3>
          <p><%= s.accroche %></p>
          <a href="/services/<%= s.slug %>" class="service-link">
            En savoir plus <i class="fa fa-arrow-right"></i>
          </a>
        </div>
      <% }) %>
    </div>

    <div class="services-cta-center">
      <a href="/services" class="btn btn-primary">
        <i class="fa fa-grid-2"></i> Voir tous nos services
      </a>
    </div>
  </div>
</section>

<!-- Why us -->
<section class="section why-section">
  <div class="container why-inner">
    <div class="why-image">
      <div class="why-img-box">
        <div class="why-img-pattern"></div>
        <div class="why-badge-float"><i class="fa fa-award"></i> Certifié ISO 9001</div>
      </div>
    </div>
    <div class="why-content">
      <span class="section-badge">Pourquoi nous choisir</span>
      <h2>La confiance au cœur de notre logistique</h2>
      <p>Depuis plus de 10 ans, Logistic Express Gabon s'impose comme le partenaire de référence pour toutes vos opérations de transport sur le territoire gabonais et à l'international.</p>
      <div class="why-points">
        <div class="why-point">
          <div class="why-icon"><i class="fa fa-bolt"></i></div>
          <div><h4>Rapidité d'exécution</h4><p>Livraisons express J+1 en ville, J+3 en province.</p></div>
        </div>
        <div class="why-point">
          <div class="why-icon"><i class="fa fa-shield-halved"></i></div>
          <div><h4>Sécurité maximale</h4><p>Toutes vos marchandises sont assurées et tracées en temps réel.</p></div>
        </div>
        <div class="why-point">
          <div class="why-icon"><i class="fa fa-headset"></i></div>
          <div><h4>Support 7j/7</h4><p>Notre équipe est disponible pour vous accompagner à chaque étape.</p></div>
        </div>
        <div class="why-point">
          <div class="why-icon"><i class="fa fa-tag"></i></div>
          <div><h4>Tarifs compétitifs</h4><p>Des prix transparents, sans frais cachés, adaptés à tous les budgets.</p></div>
        </div>
      </div>
      <a href="/a-propos" class="btn btn-primary">Découvrir notre histoire <i class="fa fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- Coverage -->
<section class="section coverage-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Notre réseau</span>
      <h2>Couverture Nationale</h2>
      <p>Nous couvrons les 9 provinces du Gabon grâce à un réseau dense d'agences et de partenaires.</p>
    </div>
    <div class="provinces-grid">
      <% const provinces = [
        {name:'Estuaire', icon:'fa-city', ville:'Libreville'},
        {name:'Ogooué-Maritime', icon:'fa-water', ville:'Port-Gentil'},
        {name:'Haut-Ogooué', icon:'fa-mountain', ville:'Franceville'},
        {name:'Woleu-Ntem', icon:'fa-tree', ville:'Oyem'},
        {name:'Ogooué-Ivindo', icon:'fa-leaf', ville:'Makokou'},
        {name:'Ngounié', icon:'fa-hill-rockslide', ville:'Mouila'},
        {name:'Nyanga', icon:'fa-sun', ville:'Tchibanga'},
        {name:'Moyen-Ogooué', icon:'fa-droplet', ville:'Lambaréné'},
        {name:'Ogooué-Lolo', icon:'fa-tree', ville:'Koulamoutou'}
      ]; %>
      <% provinces.forEach(p => { %>
      <div class="province-card">
        <i class="fa <%= p.icon %>"></i>
        <div><strong><%= p.name %></strong><span><%= p.ville %></span></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- International coverage -->
<!-- Couverture Internationale -->
<section class="section global-coverage-section">
  <div class="container">

    <div class="section-header">
      <span class="section-badge">Couverture Mondiale</span>
      <h2>Notre Réseau International</h2>
      <p>Depuis Libreville, nous connectons le Gabon aux grands pôles logistiques mondiaux. Expéditions fiables vers 150+ destinations.</p>
    </div>

    <div class="global-coverage-inner">

      <!-- Texte gauche -->
      <div class="global-coverage-text">
        <div class="gct-label">
          <i class="fa fa-globe-africa"></i>
          Interconnexion mondiale
        </div>
        <h3>Le Gabon au cœur des flux logistiques mondiaux</h3>
        <p>Notre réseau de partenaires couvre les principaux corridors cargo internationaux. Chaque pays partenaire représente une route active d'import ou d'export opérée par nos équipes.</p>

        <ul class="partners-list">
          <li>
            <img src="https://flagcdn.com/w40/cn.png" alt="Chine">
            <div>
              <strong>Chine</strong>
              <span>Équipements, électronique, composants industriels</span>
            </div>
          </li>
          <li>
            <img src="https://flagcdn.com/w40/fr.png" alt="France">
            <div>
              <strong>France</strong>
              <span>Logistique franco-gabonaise, produits de grande consommation</span>
            </div>
          </li>
          <li>
            <img src="https://flagcdn.com/w40/tr.png" alt="Turquie">
            <div>
              <strong>Turquie</strong>
              <span>Textiles, matériaux de construction, industrie</span>
            </div>
          </li>
          <li>
            <img src="https://flagcdn.com/w40/ma.png" alt="Maroc">
            <div>
              <strong>Maroc</strong>
              <span>Hub africain, distribution régionale</span>
            </div>
          </li>
          <li>
            <img src="https://flagcdn.com/w40/ae.png" alt="Émirats">
            <div>
              <strong>Émirats Arabes Unis</strong>
              <span>Fret aérien, hub de transit Moyen-Orient</span>
            </div>
          </li>
          <li>
            <img src="https://flagcdn.com/w40/kr.png" alt="Corée">
            <div>
              <strong>Corée du Sud</strong>
              <span>Technologies, électronique, véhicules</span>
            </div>
          </li>
        </ul>

        <a href="/devis" class="btn btn-primary">
          <i class="fa fa-paper-plane"></i> Expédier vers ces destinations
        </a>
      </div>

      <!-- Orbite droite -->
      <div class="orbit-layout">

        <!-- Orbites cercles décoratifs -->
        <div class="orbit orbit-1"></div>
