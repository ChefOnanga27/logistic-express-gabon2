<%- include('partials/header') %>

<section class="page-hero">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <h1>Contactez-nous</h1>
    <nav class="breadcrumb"><a href="/">Accueil</a> <i class="fa fa-chevron-right"></i> Contact</nav>
  </div>
</section>

<section class="section">
  <div class="container contact-layout">

    <div class="contact-info">
      <h3>Nos coordonnées</h3>
      <div class="contact-items">
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-map-marker-alt"></i></div>
          <div>
            <strong>Adresse</strong>
            <p>Boulevard du Bord de Mer, Zone Industrielle d'Oloumi<br>Libreville, Gabon</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-phone"></i></div>
          <div>
            <strong>Téléphone</strong>
            <p><a href="tel:+24174000000">+241 074 00 00 00</a><br><a href="tel:+24177000000">+241 077 00 00 00</a></p>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-envelope"></i></div>
          <div>
            <strong>Email</strong>
            <p><a href="mailto:contact@logistic-express-gabon.ga">contact@logistic-express-gabon.ga</a></p>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-clock"></i></div>
          <div>
            <strong>Horaires d'ouverture</strong>
            <p>Lundi – Samedi : 07h30 – 18h00<br>Dimanche : Fermé</p>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-form-box">
      <h3>Envoyez-nous un message</h3>

      <% if (success) { %>
      <div class="alert-success">
        <i class="fa fa-check-circle"></i>
        Votre message a été envoyé avec succès ! Nous vous répondrons dans les plus brefs délais.
      </div>
      <% } %>

      <form action="/contact" method="POST" class="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label>Nom complet *</label>
            <input type="text" name="nom" placeholder="Jean Dupont" required />
          </div>
          <div class="form-group">
            <label>Email *</label>
            <input type="email" name="email" placeholder="vous@email.com" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Téléphone</label>
            <input type="tel" name="telephone" placeholder="+241 0X XXX XXXX" />
          </div>
          <div class="form-group">
            <label>Objet</label>
            <select name="objet">
              <option value="">Sélectionner...</option>
              <option>Demande de devis</option>
              <option>Suivi de colis</option>
              <option>Renseignements</option>
              <option>Réclamation</option>
              <option>Autre</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Message *</label>
          <textarea name="message" rows="5" placeholder="Décrivez votre besoin..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-block">
          <i class="fa fa-paper-plane"></i> Envoyer le message
        </button>
      </form>
    </div>

  </div>
</section>

<%- include('partials/footer') %>
